# Notion internal integration token (https://www.notion.so/profile/integrations)
NOTION_TOKEN=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Set this to whatever passphrase you want to use to unlock the app.
AUTH_PASSPHRASE=

# Where to create the Stuff DBs (a Notion page id you've shared with the integration)
NOTION_PARENT_PAGE_ID=

# Filled in after running `pnpm --filter @stuff/notion run init`
NOTION_AREAS_DB_ID=
NOTION_PROJECTS_DB_ID=
NOTION_TASKS_DB_ID=
