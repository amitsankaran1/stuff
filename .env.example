# Notion internal integration token (https://www.notion.so/profile/integrations)
NOTION_TOKEN=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Set this to whatever passphrase you want to use to unlock the app.
AUTH_PASSPHRASE=

# Where to create the Stuff DBs (a Notion page id you've shared with the integration)
NOTION_PARENT_PAGE_ID=

# Filled in after running `pnpm --filter @stuff/notion run init`
NOTION_AREAS_DB_ID=
NOTION_PROJECTS_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_DEVICES_DB_ID=

# Web Push (VAPID). Generate with:
#   npx web-push generate-vapid-keys
# Subject must be a mailto: or https: URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron auth. Vercel Cron will send `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# IANA TZ used to compute "today" for the morning digest. Vercel Cron runs in
# UTC, so the schedule in vercel.json is set to fire at ~7am in this TZ.
USER_TZ=America/Los_Angeles
